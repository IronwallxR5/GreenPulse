generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImpactType {
  COMPUTE
  STORAGE
  NETWORK
  API_CALL
}

enum OrganizationRole {
  OWNER
  MEMBER
}

enum ReportFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum ReportFormat {
  PDF
  CSV
}

model User {
  id         Int          @id @default(autoincrement())
  email      String       @unique
  password   String?      // Null for Google-only accounts
  googleId   String?      @unique
  name       String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  projects   Project[]
  auditLogs  AuditLog[]
  reportSchedules   ReportSchedule[]
  complianceReports ComplianceReport[]
  organizationsOwned        Organization[]         @relation("OrganizationCreator")
  organizationMemberships   OrganizationMembership[]

  @@map("users")
}

model Project {
  id            Int          @id @default(autoincrement())
  name          String
  description   String?
  userId        Int
  organizationId Int?
  carbonBudget  Float?       // Optional CO2 threshold in kg (null = no limit set)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  impactLogs    ImpactLog[]
  alerts        Alert[]
  auditLogs     AuditLog[]
  reportSchedule    ReportSchedule?
  complianceReports ComplianceReport[]

  @@index([userId])
  @@index([organizationId])
  @@map("projects")
}

model Organization {
  id          Int                       @id @default(autoincrement())
  name        String
  createdBy   Int
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  creator     User                      @relation("OrganizationCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  memberships OrganizationMembership[]
  projects    Project[]

  @@index([createdBy])
  @@map("organizations")
}

model OrganizationMembership {
  id             Int              @id @default(autoincrement())
  organizationId Int
  userId         Int
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_memberships")
}

model ImpactLog {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  type        ImpactType
  unitValue   Float
  carbonScore Float
  projectId   Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
  @@index([createdAt])
  @@map("impact_logs")
}

model Alert {
  id          Int      @id @default(autoincrement())
  projectId   Int
  message     String
  totalCO2    Float    // Total CO2 at the time of the alert
  budget      Float    // The budget threshold that was exceeded
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@map("alerts")
}

model AuditLog {
  id          Int       @id @default(autoincrement())
  userId      Int
  projectId   Int?
  action      String
  entityType  String
  entityId    Int?
  metadata    Json?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model ReportSchedule {
  id          Int             @id @default(autoincrement())
  projectId   Int             @unique
  userId      Int
  frequency   ReportFrequency
  format      ReportFormat    @default(PDF)
  isActive    Boolean         @default(true)
  nextRunAt   DateTime
  lastRunAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports     ComplianceReport[]

  @@index([userId])
  @@index([isActive, nextRunAt])
  @@map("report_schedules")
}

model ComplianceReport {
  id          Int          @id @default(autoincrement())
  projectId   Int
  userId      Int
  scheduleId  Int?
  format      ReportFormat
  totalCO2    Float
  totalLogs   Int
  byType      Json
  generatedAt DateTime     @default(now())

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule    ReportSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([scheduleId])
  @@index([generatedAt])
  @@map("compliance_reports")
}
