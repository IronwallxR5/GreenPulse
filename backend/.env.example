DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

PORT=8080
NODE_ENV=development

JWT_SECRET="your-super-secret-key-min-32-characters"
JWT_EXPIRES_IN=7d

# Google OAuth — get these from console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Use your Render URL when deployed:
GOOGLE_CALLBACK_URL=https://<your-render-app>.onrender.com/api/auth/google/callback

# Frontend URL (Vercel URL when deployed)
FRONTEND_URL=https://<your-vercel-app>.vercel.app

# Session secret (any long random string)
SESSION_SECRET=your-session-secret